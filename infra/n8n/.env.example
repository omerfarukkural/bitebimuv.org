# === n8n Ortam Değişkenleri ===
# Bu dosyayı kopyalayıp .env olarak kaydedin: cp .env.example .env
# ASLA .env dosyasını Git'e commit etmeyin!

# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=BURAYA_GUCLU_SIFRE_GIR
POSTGRES_DB=n8n

# n8n Şifreleme (openssl rand -hex 32 ile üretin)
N8N_ENCRYPTION_KEY=BURAYA_32_KARAKTER_RASTGELE_ANAHTAR

# n8n Domain
N8N_HOST=n8n.bitebimuv.org

# n8n Admin Girişi
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=BURAYA_ADMIN_SIFRESI
